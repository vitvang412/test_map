@{
    ViewData["Title"] = "Bản đồ An ninh Đà Nẵng - Quảng Nam";
    var maptileKey = ViewData["GoongMaptileKey"]?.ToString();
    var restApiKey = ViewData["GoongRestApiKey"]?.ToString();
}

<link href="https://cdn.jsdelivr.net/npm/@@goongmaps/goong-js@1.0.9/dist/goong-js.css" rel="stylesheet" />
<link rel="stylesheet" href="~/css/map.css" asp-append-version="true" />

<!-- Container full-screen -->
<div class="gm-container">

    <!-- ════ FLOATING PANEL (Google Maps style) ════ -->
    <div class="gm-panel" id="gmPanel">

        <!-- ── STATE 1: Thanh tìm kiếm ── -->
        <div class="gm-search-wrap" id="stateSearch">
            <div class="gm-searchbar">
                <svg class="gm-search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="17" height="17">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" id="mapSearchInput"
                       placeholder="Tìm địa điểm tại Đà Nẵng, Quảng Nam..."
                       autocomplete="off"/>
                <button id="btnClearSearch" style="display:none">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <!-- Dropdown kết quả tìm kiếm -->
            <div class="gm-dropdown" id="searchDropdown" style="display:none"></div>
        </div>

        <!-- ── STATE 2: Card thông tin địa điểm ── -->
        <div class="gm-place-card" id="gmPlaceCard" style="display:none">
            <div class="gm-place-card__photo">
                <div class="gm-photo-skeleton" id="gmPhotoSkeleton"></div>
                <img id="cardPlaceImg" src="" alt="Place Photo" style="display:none" 
                     onload="this.style.display='block'; document.getElementById('gmPhotoSkeleton').style.display='none'; this.classList.add('loaded');" 
                     onerror="this.src='/images/default-place.jpg'" />
            </div>
            <div class="gm-place-card__header">
                <button class="gm-back-btn" id="btnClosePlaceCard">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </button>
                <div>
                    <div class="gm-place-name" id="cardPlaceName">—</div>
                    <div class="gm-place-addr" id="cardPlaceAddr"></div>
                </div>
            </div>
            <div class="gm-place-coords" id="cardPlaceCoords"></div>
            <div class="gm-place-actions">
                <button class="gm-action-btn gm-action-btn--primary" id="btnGetDirections">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
                        <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                    </svg>
                    Đường đi
                </button>
                <button class="gm-action-btn gm-action-btn--outline" id="btnUseMyLoc">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
                        <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M1 12h4M19 12h4"/>
                    </svg>
                    Định vị
                </button>
            </div>
        </div>

        <!-- ── STATE 3: Panel chỉ đường ── -->
        <div class="gm-route-card" id="gmRouteCard" style="display:none">

            <div class="gm-route-card__header">
                <button class="gm-back-btn" id="btnCloseRoute">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </button>
                <span>Chỉ đường</span>
                <button class="gm-swap-btn" id="btnSwapRoute" title="Đổi chiều">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                        <polyline points="17 1 21 5 17 9"/>
                        <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
                        <polyline points="7 23 3 19 7 15"/>
                        <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
                    </svg>
                </button>
            </div>

            <div class="gm-route-inputs">
                <!-- Điểm đi -->
                <div class="gm-route-field">
                    <div class="gm-route-dot gm-route-dot--from"></div>
                    <div class="gm-route-input-wrap">
                        <input type="text" id="routeStart" class="gm-route-input"
                               placeholder="Điểm xuất phát..." autocomplete="off"/>
                        <div class="gm-suggestions" id="suggStart"></div>
                    </div>
                    <button class="gm-myloc-btn" id="btnMyLocForRoute" title="Vị trí của tôi">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="13" height="13">
                            <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M1 12h4M19 12h4"/>
                        </svg>
                    </button>
                </div>
                <div class="gm-route-connector"></div>
                <!-- Điểm đến -->
                <div class="gm-route-field">
                    <div class="gm-route-dot gm-route-dot--to"></div>
                    <div class="gm-route-input-wrap">
                        <input type="text" id="routeEnd" class="gm-route-input"
                               placeholder="Điểm đến..." autocomplete="off"/>
                        <div class="gm-suggestions" id="suggEnd"></div>
                    </div>
                </div>
            </div>

            <!-- Nút tìm đường -->
            <div class="gm-route-actions">
                <button class="gm-find-btn" id="btnFindRoute">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
                        <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                    </svg>
                    Tìm đường
                </button>
            </div>

            <!-- Trạng thái -->
            <div class="gm-route-status" id="routeStatus" style="display:none"></div>

            <!-- Kết quả 3 phương tiện -->
            <div class="gm-route-results" id="routeResults" style="display:none">
                <div class="gm-result-row active" id="resDriving">
                    <span class="gm-result-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24"><path fill="currentColor" d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"></path></svg>
                    </span>
                    <div class="gm-result-body">
                        <div class="gm-result-time" id="timeCar">—</div>
                        <div class="gm-result-dist" id="distCar">—</div>
                    </div>
                    <div class="gm-result-badge">Nhanh</div>
                </div>
                <div class="gm-result-row" id="resMoto">
                    <span class="gm-result-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24"><path fill="currentColor" d="M19.44 9.03L15.41 5H11v2h3.59l2 2H5c-2.8 0-5 2.2-5 5s2.2 5 5 5c2.46 0 4.45-1.69 4.9-4h4.2c.45 2.31 2.44 4 4.9 4 2.8 0 5-2.2 5-5 0-2.12-1.39-3.96-3.36-4.73zM5 17c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm14 0c-1.66 0-3-1.34-3-3 0-.09.01-.18.02-.27l3.66-3.66c1.23.41 2.15 1.51 2.29 2.89L19 14v3zM10.84 13L9.61 11h6.63l-1.92 1.92-3.48.08z"></path></svg>
                    </span>
                    <div class="gm-result-body">
                        <div class="gm-result-time" id="timeMoto">—</div>
                        <div class="gm-result-dist" id="distMoto">—</div>
                    </div>
                </div>
                <div class="gm-result-row" id="resBicycle">
                    <span class="gm-result-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24"><path fill="currentColor" d="M15.5 5.5c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zM5 12c-2.8 0-5 2.2-5 5s2.2 5 5 5 5-2.2 5-5-2.2-5-5-5zm0 8.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5zm4.8-10.1L12 8.5V13h-2V7.5l2.1-2.1c.8-.8 1.8-1.2 2.8-1.2.6 0 1.1.2 1.5.5l2.4 1.8c.7.6 1.6 1 2.7 1v-2c-.6 0-1.2-.3-1.6-.6L18.2 3c-.5-.4-1.1-.6-1.7-.5L13 3.3c-.4.1-.7.4-.9.7L10.5 6.5l1.3.9zM19 12c-2.8 0-5 2.2-5 5s2.2 5 5 5 5-2.2 5-5-2.2-5-5-5zm0 8.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z"/></svg>
                    </span>
                    <div class="gm-result-body">
                        <div class="gm-result-time" id="timeBicycle">—</div>
                        <div class="gm-result-dist" id="distBicycle">—</div>
                    </div>
                </div>
                <button class="gm-clear-btn" id="btnClearRoute">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                    Xóa tuyến đường
                </button>
            </div>

        </div><!-- /gm-route-card -->

    </div><!-- /gm-panel -->

    <!-- ════ BẢN ĐỒ ════ -->
    <div id="map"></div>

</div><!-- /gm-container -->

<!-- Nút Toggle Vệ tinh: nằm ngoài container, dùng position:fixed để không bị WebGL canvas đè -->
<button id="btnToggleSatellite" class="gm-layer-toggle" title="Bật/Tắt chế độ vệ tinh">
    <div class="gm-layer-toggle-inner">
        <div class="gm-layer-icon"></div>
        <span class="gm-layer-text" id="layerToggleText">Vệ tinh</span>
    </div>
</button>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@goongmaps/goong-js@1.0.9/dist/goong-js.js"></script>
    <script>
        window.APP_CONFIG = {
            goongMaptileKey : '@maptileKey',
            goongRestApiKey : '@restApiKey'
        };
    </script>
    <script src="~/js/map-core.js" asp-append-version="true"></script>
    <script src="~/js/map-routing.js" asp-append-version="true"></script>


}
